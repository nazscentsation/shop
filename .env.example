# =============================================
# NazScentsation — Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# =============================================

# Server
PORT=8080
ENVIRONMENT=development
SITE_URL=http://localhost:8080

# Set to false to open the shop to the public
COMING_SOON=true

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/nazscentsation?sslmode=disable

# JWT secret — must be at least 32 random characters
JWT_SECRET=change_me_to_a_long_random_secret_string_here

# CORS — set to your frontend origin in production
ALLOW_ORIGIN=http://localhost:8080

# Admin email (receives new ticket notifications)
ADMIN_EMAIL=admin@nazscentsation.com

# SMTP — leave blank to disable email (dev mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=NazScentsation <your@gmail.com>

# SMS via Twilio — leave blank to disable SMS notifications
# Sign up at https://twilio.com — free trial available
# Alternatives for Nigeria: Termii (termii.com) or Africa's Talking
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=+1234567890
